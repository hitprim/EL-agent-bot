        "specifyBody": "json",
        "jsonBody": "{{ JSON.stringify({ chat_id: $json.chatId, text: $json.text, reply_markup: $json.keyboard ? { inline_keyboard: $json.keyboard } : undefined, parse_mode: 'HTML' }) }}",
        "options": {}
