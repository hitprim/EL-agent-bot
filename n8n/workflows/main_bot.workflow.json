    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\nconst escapeSql = (s) => String(s || '').replace(/'/g, \"''\");\n\nlet telegramId, chatId, username, firstName, text, callbackData, updateType;\n\nif (body.message) {\n  updateType = 'message';\n  telegramId = body.message.from.id;\n  chatId = body.message.chat.id;\n  username = escapeSql(body.message.from.username);\n  firstName = escapeSql(body.message.from.first_name);\n  text = body.message.text || '';\n  callbackData = null;\n} else if (body.callback_query) {\n  updateType = 'callback_query';\n  telegramId = body.callback_query.from.id;\n  chatId = body.callback_query.message.chat.id;\n  username = escapeSql(body.callback_query.from.username);\n  firstName = escapeSql(body.callback_query.from.first_name);\n  text = null;\n  callbackData = body.callback_query.data;\n} else {\n  return [];\n}\n\nreturn [{ json: { telegramId, chatId, username, firstName, text, callbackData, updateType } }];"
      },
      "id": "node-02",
      "name": "Parse Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO users (telegram_id, chat_id, username, first_name)\nVALUES ({{ $json.telegramId }}, {{ $json.chatId }}, '{{ $json.username }}', '{{ $json.firstName }}')\nON DUPLICATE KEY UPDATE\n  chat_id = VALUES(chat_id),\n  username = VALUES(username),\n  first_name = VALUES(first_name)",
        "options": {}
      },
