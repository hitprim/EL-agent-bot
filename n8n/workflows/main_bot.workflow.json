      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [1760, -400],
      "alwaysOutputData": true,
      "credentials": {
        "mySql": { "id": "2", "name": "MySQL Bot DB" }
      }
