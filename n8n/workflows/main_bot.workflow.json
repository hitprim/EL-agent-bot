    {
      "parameters": {
        "jsCode": "const agents = $input.all();\nconst chatId = $('Determine Route').first().json.chatId;\n\nif (agents.length === 0 || !agents[0].json.elevenlabs_agent_id) {\n  return [{\n    json: {\n      chatId,\n      text: 'Р РҲ Р РҶР В°РЎРғ Р Р…Р ВөРЎвҖҡ Р С—Р С•Р Т‘Р С”Р В»РЎРӢРЎвҖЎРЎвҖҳР Р…Р Р…РЎвҖ№РЎвҖҰ Р В°Р С–Р ВөР Р…РЎвҖҡР С•Р РҶ.\\n\\nР вҖқР С•Р ВұР В°Р РҶРЎРҠРЎвҖҡР Вө Р В°Р С–Р ВөР Р…РЎвҖҡР В° Р С”Р С•Р СҳР В°Р Р…Р Т‘Р С•Р в„–:\\n/add {elevenlabs_agent_id}',\n      keyboard: null\n    }\n  }];\n}\n\nconst keyboard = agents.map(item => [{\n  text: item.json.agent_name,\n  callback_data: 'select_agent:' + item.json.elevenlabs_agent_id\n}]);\n\nreturn [{ json: { chatId, text: 'Р вҖҷР В°РЎвӮ¬Р С‘ Р С–Р С•Р В»Р С•РЎРғР С•Р РҶРЎвҖ№Р Вө Р В°Р С–Р ВөР Р…РЎвҖҡРЎвҖ№ - Р РҶРЎвҖ№Р ВұР ВөРЎРӮР С‘РЎвҖҡР Вө Р Т‘Р В»РЎРҸ РЎС“Р С—РЎРӮР В°Р РҶР В»Р ВөР Р…Р С‘РЎРҸ:', keyboard } }];"
      },
