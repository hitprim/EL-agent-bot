    {
      "parameters": {
        "jsCode": "const agents = $input.all();\nconst chatId = $('Determine Route').first().json.chatId;\n\nif (agents.length === 0 || !agents[0].json.elevenlabs_agent_id) {\n  return [{\n    json: {\n      chatId,\n      text: 'РЈ РІР°СЃ РЅРµС‚ РїРѕРґРєР»СЋС‡С‘РЅРЅС‹С… Р°РіРµРЅС‚РѕРІ.\\n\\nР”РѕР±Р°РІСЊС‚Рµ Р°РіРµРЅС‚Р° РєРѕРјР°РЅРґРѕР№:\\n/add {elevenlabs_agent_id}',\n      keyboard: null\n    }\n  }];\n}\n\nconst keyboard = agents.map(item => [{\n  text: item.json.agent_name,\n  callback_data: 'select_agent:' + item.json.elevenlabs_agent_id\n}]);\n\nreturn [{ json: { chatId, text: 'Р’Р°С€Рё РіРѕР»РѕСЃРѕРІС‹Рµ Р°РіРµРЅС‚С‹ - РІС‹Р±РµСЂРёС‚Рµ РґР»СЏ СѓРїСЂР°РІР»РµРЅРёСЏ:', keyboard } }];"
      },
      "id": "node-10",
      "name": "Build Agent List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, -400]
    },

