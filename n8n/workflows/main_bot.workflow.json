        "jsonBody": "{{ JSON.stringify({ chat_id: $('Extract Agent ID').first().json.chatId, text: 'РђРіРµРЅС‚ РІС‹Р±СЂР°РЅ. Р§С‚Рѕ С…РѕС‚РёС‚Рµ РёР·РјРµРЅРёС‚СЊ?', reply_markup: { inline_keyboard: [ [{ text: 'вњЏпёЏ РР·РјРµРЅРёС‚СЊ РїСЂРѕРјРїС‚', callback_data: 'edit_prompt:' + $('Extract Agent ID').first().json.agentId }], [{ text: 'рџ‘‹ РР·РјРµРЅРёС‚СЊ РїСЂРёРІРµС‚СЃС‚РІРёРµ', callback_data: 'edit_welcome:' + $('Extract Agent ID').first().json.agentId }], [{ text: 'рџ“љ РћР±РЅРѕРІРёС‚СЊ Р±Р°Р·Сѓ Р·РЅР°РЅРёР№', callback_data: 'edit_kb:' + $('Extract Agent ID').first().json.agentId }], [{ text: 'В« РќР°Р·Р°Рґ Рє СЃРїРёСЃРєСѓ', callback_data: 'cancel' }] ] } }) }}",
