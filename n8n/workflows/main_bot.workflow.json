{
  "name": "YMTech Bot - Main",
  "nodes": [

    {
      "parameters": {
        "updates": ["message", "callback_query"],
        "additionalFields": {}
      },
      "id": "node-01",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [0, 300],
      "webhookId": "ymtech-bot-main-webhook",
      "credentials": {
        "telegramApi": { "id": "1", "name": "Telegram Bot" }
      }
    },

    {
      "parameters": {
        "jsCode": "// РџР°СЂСЃРёРј Telegram update + СЌРєСЂР°РЅРёСЂСѓРµРј СЃС‚СЂРѕРєРё РґР»СЏ SQL\nconst body = $input.first().json;\nconst escapeSql = (s) => String(s || '').replace(/'/g, \"''\");\n\nlet telegramId, chatId, username, firstName, text, callbackData, updateType;\n\nif (body.message) {\n  updateType = 'message';\n  telegramId = body.message.from.id;\n  chatId = body.message.chat.id;\n  username = escapeSql(body.message.from.username);\n  firstName = escapeSql(body.message.from.first_name);\n  text = body.message.text || '';\n  callbackData = null;\n} else if (body.callback_query) {\n  updateType = 'callback_query';\n  telegramId = body.callback_query.from.id;\n  chatId = body.callback_query.message.chat.id;\n  username = escapeSql(body.callback_query.from.username);\n  firstName = escapeSql(body.callback_query.from.first_name);\n  text = null;\n  callbackData = body.callback_query.data;\n} else {\n  return [];\n}\n\nreturn [{ json: { telegramId, chatId, username, firstName, text, callbackData, updateType } }];"
      },
      "id": "node-02",
      "name": "Parse Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO users (telegram_id, chat_id, username, first_name)\nVALUES ({{ $json.telegramId }}, {{ $json.chatId }}, '{{ $json.username }}', '{{ $json.firstName }}')\nON DUPLICATE KEY UPDATE\n  chat_id = VALUES(chat_id),\n  username = VALUES(username),\n  first_name = VALUES(first_name)",
        "options": {}
      },
      "id": "node-03",
      "name": "Upsert User",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [440, 300],
      "credentials": {
        "mySql": { "id": "2", "name": "MySQL Bot DB" }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT id FROM users WHERE telegram_id = {{ $('Parse Update').first().json.telegramId }}",
        "options": {}
      },
      "id": "node-04",
      "name": "Get User ID",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [660, 300],
      "credentials": {
        "mySql": { "id": "2", "name": "MySQL Bot DB" }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT IGNORE INTO user_sessions (user_id, state) VALUES ({{ $json.id }}, 'idle')",
        "options": {}
      },
      "id": "node-05",
      "name": "Init Session",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [880, 300],
      "credentials": {
        "mySql": { "id": "2", "name": "MySQL Bot DB" }
      }
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT state, selected_agent_id FROM user_sessions WHERE user_id = {{ $('Get User ID').first().json.id }}",
        "options": {}
      },
      "id": "node-06",
      "name": "Get Session",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [1100, 300],
      "alwaysOutputData": true,
      "credentials": {
        "mySql": { "id": "2", "name": "MySQL Bot DB" }
      }
    },

    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Update').first().json;\nconst userRow = $('Get User ID').first().json;\nconst sessionRow = $('Get Session').first().json || {};\n\nconst userId = userRow.id;\nconst state = sessionRow.state || 'idle';\nconst selectedAgentId = sessionRow.selected_agent_id || null;\nconst { telegramId, chatId, username, firstName, text, callbackData, updateType } = parsed;\n\nlet route = 'fallback';\n\n// Cancel callback Рё /start СЂР°Р±РѕС‚Р°СЋС‚ РІСЃРµРіРґР°, РЅРµР·Р°РІРёСЃРёРјРѕ РѕС‚ state\nif (callbackData === 'cancel') {\n  route = 'cancel';\n} else if (text === '/start' || text === '/menu') {\n  route = 'start';\n} else if (state === 'idle') {\n  if (callbackData && callbackData.startsWith('select_agent:')) {\n    route = 'select_agent';\n  } else if (callbackData && callbackData.startsWith('edit_prompt:')) {\n    route = 'edit_prompt';\n  } else if (callbackData && callbackData.startsWith('edit_welcome:')) {\n    route = 'edit_welcome';\n  } else if (callbackData && callbackData.startsWith('edit_kb:')) {\n    route = 'edit_kb';\n  } else if (text && text.startsWith('/add ')) {\n    route = 'add_agent';\n  }\n} else if (state === 'await_prompt' && text) {\n  // Р’ await_ СЃРѕСЃС‚РѕСЏРЅРёСЏС… РїСЂРёРЅРёРјР°РµРј С‚РѕР»СЊРєРѕ С‚РµРєСЃС‚РѕРІС‹Рµ СЃРѕРѕР±С‰РµРЅРёСЏ\n  route = 'await_prompt';\n} else if (state === 'await_welcome' && text) {\n  route = 'await_welcome';\n} else if (state === 'await_kb' && text) {\n  route = 'await_kb';\n}\n\nreturn [{ json: { telegramId, chatId, username, firstName, text, callbackData, updateType, userId, state, selectedAgentId, route } }];"
      },
      "id": "node-07",
      "name": "Determine Route",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 300]
    },

    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "start", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "start"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "select_agent", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "select_agent"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "edit_prompt", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "edit_prompt"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "edit_welcome", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "edit_welcome"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "edit_kb", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "edit_kb"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "await_prompt", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "await_prompt"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "await_welcome", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "await_welcome"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "await_kb", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "await_kb"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "add_agent", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "add_agent"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "cancel", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "cancel"
            }
          ]
        },
        "fallbackOutput": "extra",
        "options": {}
      },
      "id": "node-08",
      "name": "Route Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1540, 300]
    },

    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT elevenlabs_agent_id, agent_name FROM user_agents WHERE user_id = {{ $json.userId }} ORDER BY created_at ASC",
        "options": {}
      },
