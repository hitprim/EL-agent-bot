    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Update').first().json;\nconst userRow = $('Get User ID').first().json;\nconst sessionRow = $('Get Session').first().json || {};\n\nconst userId = userRow.id;\nconst state = sessionRow.state || 'idle';\nconst selectedAgentId = sessionRow.selected_agent_id || null;\nconst { telegramId, chatId, username, firstName, text, callbackData, updateType } = parsed;\n\nlet route = 'fallback';\n\nif (callbackData === 'cancel') {\n  route = 'cancel';\n} else if (text === '/start' || text === '/menu') {\n  route = 'start';\n} else if (state === 'idle') {\n  if (callbackData && callbackData.startsWith('select_agent:')) {\n    route = 'select_agent';\n  } else if (callbackData && callbackData.startsWith('edit_prompt:')) {\n    route = 'edit_prompt';\n  } else if (callbackData && callbackData.startsWith('edit_welcome:')) {\n    route = 'edit_welcome';\n  } else if (callbackData && callbackData.startsWith('edit_kb:')) {\n    route = 'edit_kb';\n  } else if (text && text.startsWith('/add ')) {\n    route = 'add_agent';\n  }\n} else if (state === 'await_prompt' && text) {\n  route = 'await_prompt';\n} else if (state === 'await_welcome' && text) {\n  route = 'await_welcome';\n} else if (state === 'await_kb' && text) {\n  route = 'await_kb';\n}\n\nreturn [{ json: { telegramId, chatId, username, firstName, text, callbackData, updateType, userId, state, selectedAgentId, route } }];"
      },
      "id": "node-07",
      "name": "Determine Route",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 300]
    },

    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "start", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "start"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "select_agent", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "select_agent"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "edit_prompt", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "edit_prompt"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "edit_welcome", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "edit_welcome"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "edit_kb", "operator": { "type": "string", "operation": "equals" } }] },
              "renameOutput": true, "outputKey": "edit_kb"
            },
            {
              "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.route }}", "rightValue": "await_prompt", "operator": { "type": "string", "operation": "equals" } }] },
